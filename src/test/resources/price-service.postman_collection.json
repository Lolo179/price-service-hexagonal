        {
          "name": "400 — Parámetro requerido ausente (brandId)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/prices?applicationDate=2020-06-14T10:00:00&productId={{productId}}",
