{
  "info": {
    "name": "Price Service",
    "description": "Colección de tests para el servicio de precios de Inditex.\n\nBase URL: http://localhost:8080\n\nAntes de ejecutar, arrancar la aplicación con:\n  .\\mvnw.cmd spring-boot:run",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "35455",
      "type": "string"
    },
    {
      "key": "brandId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Casos requeridos del ejercicio",
      "item": [
        {
          "name": "Test 1 — 10:00 día 14 → tarifa 1 (35.50€)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/prices?applicationDate=2020-06-14T10:00:00&productId={{productId}}&brandId={{brandId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "prices"],
              "query": [
                { "key": "applicationDate", "value": "2020-06-14T10:00:00" },
                { "key": "productId",       "value": "{{productId}}" },
                { "key": "brandId",         "value": "{{brandId}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('priceList = 1', () => pm.expect(body.priceList).to.eql(1));",
                  "pm.test('price = 35.5',  () => pm.expect(body.price).to.eql(35.5));",
                  "pm.test('currency = EUR',() => pm.expect(body.currency).to.eql('EUR'));"
                ]
              }
            }
          ]
        },
        {
