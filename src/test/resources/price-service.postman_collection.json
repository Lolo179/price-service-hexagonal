              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('Body tiene message', () => pm.expect(pm.response.json()).to.have.property('message'));"
                ]
